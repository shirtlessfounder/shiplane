# Template for /etc/<app>/prod.env on the exe.dev VM.
# Store at 0600. systemd reads this via EnvironmentFile=.
# Never commit a filled-in version to git.

# ---- server ----
PORT=3000
NODE_ENV=production

# ---- supabase ----
# transaction pooler (:6543) for normal queries
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:6543/postgres?sslmode=no-verify

# session pooler (:5432) for LISTEN/NOTIFY / logical replication
DATABASE_URL_SESSION=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=no-verify

# ---- upstreams (examples — drop if not applicable) ----
# ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com
# OPENAI_UPSTREAM_BASE_URL=https://api.openai.com
# UPSTREAM_TIMEOUT_MS=120000

# ---- tokens — generate fresh, rotate periodically ----
# ADMIN_TOKEN=<sha256 hex, used for admin-scoped API routes>
# ORG_SESSION_SECRET=<random 32+ byte hex, used for cookie signing>

# ---- github oauth (if your app has social login) ----
# ORG_GITHUB_CLIENT_ID=
# ORG_GITHUB_CLIENT_SECRET=
# ORG_GITHUB_CALLBACK_URL=https://<host>.exe.xyz/v1/org/auth/github/callback
# ORG_GITHUB_STATE_SECRET=

# ---- misc ----
# INNIES_BASE_URL=https://<host>.exe.xyz
# PILOT_UI_BASE_URL=https://<product>.vercel.app
